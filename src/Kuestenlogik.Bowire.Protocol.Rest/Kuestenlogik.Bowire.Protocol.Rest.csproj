<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <Description>Bowire REST protocol plugin — discovers REST endpoints via OpenAPI 3 / Swagger and lets you exercise them with the same form-based UI used for gRPC.</Description>
    <PackageId>Kuestenlogik.Bowire.Protocol.Rest</PackageId>
    <PackageTags>bowire;bowire-plugin;rest;openapi;swagger;http;developer-tools</PackageTags>
    <IsPackable>true</IsPackable>
  </PropertyGroup>
  <ItemGroup>
    <InternalsVisibleTo Include="bowire" />
    <InternalsVisibleTo Include="Kuestenlogik.Bowire.Tests" />
    <InternalsVisibleTo Include="Kuestenlogik.Bowire.Protocol.Rest.Tests" />
    <InternalsVisibleTo Include="Kuestenlogik.Bowire.IntegrationTests" />
  </ItemGroup>
  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>
  <ItemGroup>
    <!-- Microsoft.OpenApi extracted into per-version adapter packages
         (Kuestenlogik.Bowire.Protocol.Rest.OpenApi2 vs .OpenApi3) so
         embedded ASP.NET hosts can pin the version that matches their
         own AddOpenApi() pipeline. Bowire.Protocol.Rest itself goes
         through IBowireOpenApiAdapter at runtime — see
         BowireOpenApiAdapterRegistry. -->
    <!-- YAML serialisation for the OpenAPI exporter + the mock-host
         JSON↔YAML format converter behind /openapi.{json,yaml}. Same
         dependency the AsyncApi project already ships. -->
    <PackageReference Include="YamlDotNet" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\Kuestenlogik.Bowire\Kuestenlogik.Bowire.csproj" />
    <!-- Mock for the OpenApiMockSchemaSource adapter. -->
    <ProjectReference Include="..\Kuestenlogik.Bowire.Mock\Kuestenlogik.Bowire.Mock.csproj" />
  </ItemGroup>
</Project>
