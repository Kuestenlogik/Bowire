<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <Description>Bowire SOAP / WSDL protocol plugin — browse and invoke any SOAP service. Discovery parses the WSDL document (?wsdl convention or direct WSDL URL); invocation wraps the JSON form input into a SOAP 1.1 or 1.2 envelope, POSTs it with the right SOAPAction header, and surfaces the response body back as JSON.</Description>
    <PackageId>Kuestenlogik.Bowire.Protocol.Soap</PackageId>
    <PackageTags>bowire;bowire-plugin;soap;wsdl;ws;developer-tools</PackageTags>
    <IsPackable>true</IsPackable>
  </PropertyGroup>
  <ItemGroup>
    <InternalsVisibleTo Include="bowire" />
    <InternalsVisibleTo Include="Kuestenlogik.Bowire.Tests" />
    <InternalsVisibleTo Include="Kuestenlogik.Bowire.IntegrationTests" />
  </ItemGroup>
  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\Kuestenlogik.Bowire\Kuestenlogik.Bowire.csproj" />
  </ItemGroup>
</Project>
