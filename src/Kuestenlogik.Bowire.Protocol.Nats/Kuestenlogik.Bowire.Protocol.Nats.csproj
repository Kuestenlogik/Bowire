<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <Description>Bowire NATS protocol plugin — pub/sub + request/reply on NATS subjects via the official NATS.Net client. Subjects map to services, publish/subscribe/request map to unary/streaming methods.</Description>
    <PackageId>Kuestenlogik.Bowire.Protocol.Nats</PackageId>
    <PackageTags>bowire;bowire-plugin;nats;nats-io;pubsub;messaging;developer-tools</PackageTags>
    <IsPackable>true</IsPackable>
    <!-- CA1873: false positive on debug log calls whose template
         arguments are property/local reads. Same suppression as Mqtt. -->
    <NoWarn>$(NoWarn);CA1873</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="bowire" />
    <InternalsVisibleTo Include="Kuestenlogik.Bowire.Tests" />
    <InternalsVisibleTo Include="Kuestenlogik.Bowire.IntegrationTests" />
  </ItemGroup>

  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Kuestenlogik.Bowire\Kuestenlogik.Bowire.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="NATS.Net" />
  </ItemGroup>

</Project>
