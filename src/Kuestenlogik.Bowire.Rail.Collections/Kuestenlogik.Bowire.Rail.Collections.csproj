<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <!-- #306 Phase G — Collections rail package. Hidden from rail strip
         but kept in catalogue so workspace trees can dispatch into it.
         #314 — owns collections.js fragment (Parallel Sessions + collection
         manager runtime). Stitched into the workbench bundle via the
         #311 BowireHtmlGenerator.StitchRailFragments pipeline. -->
    <Description>Bowire Collections rail — hidden from the rail strip; surfaces the saved-request collections inside their workspace. Adds the Collections rail descriptor + per-rail JS fragment to the workbench.</Description>
    <PackageId>Kuestenlogik.Bowire.Rail.Collections</PackageId>
    <PackageTags>bowire;rail;collections;workbench;plugin</PackageTags>
    <IsPackable>true</IsPackable>
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="..\Kuestenlogik.Bowire\Kuestenlogik.Bowire.csproj" />
  </ItemGroup>
  <ItemGroup>
    <!-- #314 — per-rail JS fragment. Core's HTML generator scans every
         embedded resource whose LogicalName matches
         `Kuestenlogik.Bowire.Rail.*.wwwroot.js.*.js`, concatenates the
         payloads, and stitches them into the workbench bundle's IIFE
         right before init.js. Hosts that don't reference this package
         don't ship the fragment — that's the byte-count win this issue
         was tracking. -->
    <EmbeddedResource Include="wwwroot\js\collections.js"
                      LogicalName="Kuestenlogik.Bowire.Rail.Collections.wwwroot.js.collections.js" />
  </ItemGroup>
</Project>
