<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <Description>Bowire gRPC protocol plugin — auto-discovered service browser via gRPC Server Reflection.</Description>
    <PackageId>Kuestenlogik.Bowire.Protocol.Grpc</PackageId>
    <PackageTags>bowire;bowire-plugin;grpc;reflection;protobuf;developer-tools</PackageTags>
    <IsPackable>true</IsPackable>
    <!-- CA1873: false positive on debug log calls whose arguments are
         property/local reads. Same suppression as Mock and Mqtt. -->
    <NoWarn>$(NoWarn);CA1873</NoWarn>
  </PropertyGroup>
  <ItemGroup>
    <InternalsVisibleTo Include="bowire" />
    <InternalsVisibleTo Include="Kuestenlogik.Bowire.Tests" />
    <InternalsVisibleTo Include="Kuestenlogik.Bowire.IntegrationTests" />
  </ItemGroup>
  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\Kuestenlogik.Bowire\Kuestenlogik.Bowire.csproj" />
    <!-- ProjectReference to Mock so the schema-only mock + reflection
         hosting extensions can pick up Mocking contracts. Same pattern
         as Protocol.Mqtt. -->
    <ProjectReference Include="..\Kuestenlogik.Bowire.Mock\Kuestenlogik.Bowire.Mock.csproj" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="Google.Api.CommonProtos" />
    <PackageReference Include="Grpc.AspNetCore" />
    <PackageReference Include="Grpc.AspNetCore.Server.Reflection" />
    <PackageReference Include="Grpc.Net.Client" />
    <PackageReference Include="Grpc.Net.Client.Web" />
    <PackageReference Include="Grpc.Reflection" />
    <PackageReference Include="Google.Protobuf" />
  </ItemGroup>
</Project>
