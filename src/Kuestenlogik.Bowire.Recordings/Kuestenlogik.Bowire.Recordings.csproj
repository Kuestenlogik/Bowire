<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <!-- #306 Phase G — Recordings rail package.
         #311 Phase G continuation — owns recording.js fragment.
         v2.1 (#325): renamed from Kuestenlogik.Bowire.Rail.Recordings to
         drop the Rail. prefix. -->
    <Description>Bowire Recordings rail — capture + replay traffic. Adds the Recordings rail descriptor + per-rail JS fragment to the workbench.</Description>
    <PackageId>Kuestenlogik.Bowire.Recordings</PackageId>
    <PackageTags>bowire;rail;recordings;workbench;plugin</PackageTags>
    <IsPackable>true</IsPackable>
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="..\Kuestenlogik.Bowire\Kuestenlogik.Bowire.csproj" />
  </ItemGroup>
  <ItemGroup>
    <!-- #311 — per-rail JS fragment. The core HTML generator discovers
         every embedded resource whose LogicalName matches
         `Kuestenlogik.Bowire.*.wwwroot.js.*.js`, concatenates the
         payloads, and stitches them into the workbench bundle's IIFE
         right before init.js. Hosts that don't reference this package
         don't ship the fragment — the byte-count win of #311. -->
    <EmbeddedResource Include="wwwroot\js\recording.js"
                      LogicalName="Kuestenlogik.Bowire.Recordings.wwwroot.js.recording.js" />
  </ItemGroup>
</Project>
