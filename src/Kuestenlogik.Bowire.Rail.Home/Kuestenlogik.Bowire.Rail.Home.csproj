<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <!--
      #306 Phase G — Home rail package. Ships only the descriptor; the
      sidebar / main-pane render code still lives in core wwwroot/js
      until the per-package JS fragment concat pipeline lands (see the
      'Phase G continuation' follow-up). Embedded hosts that don't
      reference this package don't see the Home rail in __BOWIRE_CONFIG__.rails.
    -->
    <Description>Bowire Home rail — cross-workflow landing surface. Adds the Home rail descriptor to the rail registry; embedded hosts that don't reference this package don't get the rail at all.</Description>
    <PackageId>Kuestenlogik.Bowire.Rail.Home</PackageId>
    <PackageTags>bowire;rail;home;workbench;plugin</PackageTags>
    <IsPackable>true</IsPackable>
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="..\Kuestenlogik.Bowire\Kuestenlogik.Bowire.csproj" />
  </ItemGroup>
</Project>
