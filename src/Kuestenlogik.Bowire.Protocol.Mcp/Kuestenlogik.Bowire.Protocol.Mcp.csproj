<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <Description>Bowire MCP protocol plugin -- exposes discovered API services as MCP tools for AI agents (Claude, Copilot, Cursor).</Description>
    <PackageId>Kuestenlogik.Bowire.Protocol.Mcp</PackageId>
    <PackageTags>bowire;bowire-plugin;mcp;ai;claude;copilot;cursor;tools;model-context-protocol</PackageTags>
    <IsPackable>true</IsPackable>
  </PropertyGroup>
  <ItemGroup>
    <InternalsVisibleTo Include="bowire" />
    <InternalsVisibleTo Include="Kuestenlogik.Bowire.Tests" />
    <InternalsVisibleTo Include="Kuestenlogik.Bowire.IntegrationTests" />
  </ItemGroup>
  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\Kuestenlogik.Bowire\Kuestenlogik.Bowire.csproj" />
    <!-- Official MCP C# SDK — discovery + invoke path uses
         ModelContextProtocol.Client.McpClient instead of a hand-rolled
         JSON-RPC pipeline. The adapter-server side (McpAdapterServer)
         is still self-contained and doesn't take a runtime dep. -->
    <PackageReference Include="ModelContextProtocol" />
    <!-- AspNetCore package brings app.MapMcp(pattern) for mounting
         the streamable-HTTP transport on the host's route table.
         The adapter (Bowire-as-MCP-server) leans on that for the
         transport plumbing; tools / resources / prompts are still
         injected dynamically via the With*Handler builder API. -->
    <PackageReference Include="ModelContextProtocol.AspNetCore" />
  </ItemGroup>
</Project>
