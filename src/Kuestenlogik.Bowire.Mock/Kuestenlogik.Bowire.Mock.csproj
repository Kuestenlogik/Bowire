<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <Description>Bowire mock server + Mocks rail UI — ships both the mock-host runtime (MockServer, MockHandler, MockOptions, MockServerOptions) that replays Bowire recordings as a live local API endpoint (REST + gRPC unary replay, SSE / WebSocket / SignalR / MQTT streaming replay with captured frame cadence, schema-only mocks from OpenAPI / proto FileDescriptorSet / GraphQL SDL, chaos injection, stateful cursors, capture-on-miss) AND the BowireMocksRailContribution + the per-rail JS fragment the workbench stitches into its bundle. Run via `bowire mock --recording &lt;file&gt;`, embed with `app.UseBowireMock(...)`, or reference the package from an embedded workbench host to get the Mocks rail. The provisional Kuestenlogik.Bowire.Rail.Mocks package was folded in for v2.1.</Description>
    <PackageId>Kuestenlogik.Bowire.Mock</PackageId>
    <PackageTags>bowire;mock-server;mocks-rail;api-testing;replay;recording;openapi;protobuf;graphql;chaos-engineering;workbench;plugin;developer-tools</PackageTags>
    <IsPackable>true</IsPackable>
  </PropertyGroup>
  <ItemGroup>
    <InternalsVisibleTo Include="bowire" />
    <InternalsVisibleTo Include="Kuestenlogik.Bowire.Mock.Tests" />
    <InternalsVisibleTo Include="Kuestenlogik.Bowire.Mock.IntegrationTests" />
  </ItemGroup>
  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>
  <ItemGroup>
    <!-- Kuestenlogik.Bowire owns the mock-emitter contract types
         (IBowireMockEmitter, BowireRecording, MockEmitterOptions) under
         the Kuestenlogik.Bowire.Mocking namespace. Mock picks them up from there;
         plugins reference only Kuestenlogik.Bowire and never inherit the heavy
         packages below. -->
    <ProjectReference Include="..\Kuestenlogik.Bowire\Kuestenlogik.Bowire.csproj" />
  </ItemGroup>
  <ItemGroup>
    <!-- #311 — per-rail JS fragment. BowireHtmlGenerator.CollectRailJsPayload
         scans loaded Bowire assemblies (Rail.* / Security.* / Mock) for
         resources whose LogicalName contains `.wwwroot.js.` and ends with
         `.js`, then stitches them into the workbench bundle. The Mocks
         rail's contribution + fragment used to ship in the provisional
         Kuestenlogik.Bowire.Rail.Mocks package; folded in here for v2.1
         so operators don't have to deprecate a separate package once
         Rail.Mocks would have hit NuGet. -->
    <EmbeddedResource Include="wwwroot\js\mocks.js"
                      LogicalName="Kuestenlogik.Bowire.Mock.wwwroot.js.mocks.js" />
  </ItemGroup>
  <!-- All protocol-specific dependencies (MQTTnet/MQTTnet.Server,
       Google.Protobuf, Grpc.AspNetCore, Grpc.Reflection,
       Microsoft.OpenApi.Readers, GraphQL-Parser) hung here until the
       mock plugin-isation refactor. They now live on the matching
       protocol plugins (Protocol.Mqtt, Protocol.Grpc, Protocol.Rest,
       Protocol.GraphQL), each of which contributes an
       IBowireMockTransportHost / IBowireMockSchemaSource /
       IBowireMockHostingExtension the mock server discovers at
       startup. Kuestenlogik.Bowire.Mock has zero compile-time protocol-library
       knowledge — pure orchestrator. -->
  <PropertyGroup>
    <!-- CA1873: the rule fires on structured-logging arguments that are just
         property accesses. For this project's volume of log calls the
         source-generated LoggerMessage alternative is overkill. -->
    <NoWarn>$(NoWarn);CA1873</NoWarn>
  </PropertyGroup>
</Project>
