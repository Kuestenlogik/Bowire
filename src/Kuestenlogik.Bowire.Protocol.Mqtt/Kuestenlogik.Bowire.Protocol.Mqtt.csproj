<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <Description>Bowire MQTT protocol plugin — MQTT 3.1.1 / 5.0 via MQTTnet. Topics map to services, publish/subscribe map to unary/streaming.</Description>
    <PackageId>Kuestenlogik.Bowire.Protocol.Mqtt</PackageId>
    <PackageTags>bowire;bowire-plugin;mqtt;broker;iot;pubsub;developer-tools</PackageTags>
    <IsPackable>true</IsPackable>
    <!-- CA1873: false positive on debug log calls whose template
         arguments are property/local reads (no allocation, no virtual
         dispatch). Same suppression as Kuestenlogik.Bowire.Mock and Mcp. -->
    <NoWarn>$(NoWarn);CA1873</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="bowire" />
    <InternalsVisibleTo Include="Kuestenlogik.Bowire.Tests" />
    <InternalsVisibleTo Include="Kuestenlogik.Bowire.IntegrationTests" />
  </ItemGroup>

  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Kuestenlogik.Bowire\Kuestenlogik.Bowire.csproj" />
    <!-- ProjectReference to Kuestenlogik.Bowire.Mock so the plugin's
         MqttMockTransportHost can reuse Mock's ResponseBodySubstitutor
         (template substitution is protocol-agnostic infrastructure that
         lives there). The dep flows correctly: Mqtt-plugin → Mock,
         not the other way around — Mock has no compile-time knowledge
         of the Mqtt plugin. Plugins that don't use the mock surface
         can ignore this transitive ref. -->
    <ProjectReference Include="..\Kuestenlogik.Bowire.Mock\Kuestenlogik.Bowire.Mock.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="MQTTnet" />
    <!-- MQTTnet.Server — needed by MqttMockTransportHost to spin up an
         embedded broker for recording replay. Lived on Kuestenlogik.Bowire.Mock
         until the plugin-isation refactor. -->
    <PackageReference Include="MQTTnet.Server" />
  </ItemGroup>

</Project>
