<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <Description>Bowire security scanner — Tier-1 anchor of the security-testing lane. Loads vulnerability templates (BowireRecordings flagged with `attack: true`), replays them against a target, evaluates the AttackPredicate against the response, and emits findings as SARIF 2.1.0. Ships with built-in passive checks (TLS-version enumeration, version-disclosing headers, verbose-error detection). Pluggable: scoped, auth-header-aware, per-probe timeout-bounded.</Description>
    <PackageId>Kuestenlogik.Bowire.Security.Scanner</PackageId>
    <PackageTags>bowire;security;vulnerability-scanner;sarif;owasp;api-security;developer-tools</PackageTags>
    <IsPackable>true</IsPackable>
    <!-- CA1303 (literal strings should be resourced) is suppressed
         to match Tool's policy — this project carries the same kind
         of CLI banner / progress output, no localisation planned. -->
    <NoWarn>$(NoWarn);CA1303</NoWarn>
  </PropertyGroup>
  <ItemGroup>
    <InternalsVisibleTo Include="bowire" />
    <InternalsVisibleTo Include="Kuestenlogik.Bowire.Tests" />
    <InternalsVisibleTo Include="Kuestenlogik.Bowire.IntegrationTests" />
  </ItemGroup>
  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\Kuestenlogik.Bowire\Kuestenlogik.Bowire.csproj" />
    <!-- ScanCliCommand implements IBowireCliCommand → needs the CLI
         contract package, which carries the System.CommandLine
         dependency. Core Kuestenlogik.Bowire is CL-free since v1.6.0. -->
    <ProjectReference Include="..\Kuestenlogik.Bowire.Cli\Kuestenlogik.Bowire.Cli.csproj" />
    <!-- Templates.Nuclei lets the `nuclei` flag read the
         projectdiscovery/nuclei-templates corpus alongside the
         scanner's native JSON-template shape. Scanner depends on
         Templates.Nuclei rather than the other way: Templates.Nuclei
         only emits Core types, so embedded users can pull it
         standalone (e.g. a corpus-converter tool) without dragging
         in the scan-engine. -->
    <ProjectReference Include="..\Kuestenlogik.Bowire.Security.Templates.Nuclei\Kuestenlogik.Bowire.Security.Templates.Nuclei.csproj" />
  </ItemGroup>
  <!-- #306/#314 — the Security rail's JS fragment. Embedded with the
       `.wwwroot.js.<file>.js` logical-name convention so core's
       StitchRailFragments splices it into the workbench bundle at the
       rail-fragment marker; the fragment registers renderSecuritySidebar
       / renderSecurityMain on the renderer-key seam. -->
  <ItemGroup>
    <EmbeddedResource Include="wwwroot\js\security.js"
                      LogicalName="Kuestenlogik.Bowire.Security.Scanner.wwwroot.js.security.js" />
  </ItemGroup>
</Project>
