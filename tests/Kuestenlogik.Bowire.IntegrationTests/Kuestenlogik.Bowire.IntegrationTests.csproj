<Project Sdk="Microsoft.NET.Sdk.Web">
  <PropertyGroup>
    <IsPackable>false</IsPackable>
    <IsTestProject>true</IsTestProject>
    <NoWarn>$(NoWarn);CA1515</NoWarn>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="Microsoft.NET.Test.Sdk" />
    <PackageReference Include="xunit.v3" />
    <PackageReference Include="xunit.runner.visualstudio" />
    <PackageReference Include="coverlet.collector"><PrivateAssets>all</PrivateAssets><IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets></PackageReference>
    <PackageReference Include="Microsoft.AspNetCore.Mvc.Testing" />
    <PackageReference Include="Grpc.AspNetCore" />
    <PackageReference Include="Grpc.AspNetCore.Server.Reflection" />
    <!-- Used by GrpcWebIntegrationTests to host the GreeterService
         fixture behind app.UseGrpcWeb() over HTTP/1.1. -->
    <PackageReference Include="Grpc.AspNetCore.Web" />
    <PackageReference Include="Grpc.Tools" PrivateAssets="All" />
    <!-- Testcontainers (+ .Pulsar): the Pulsar round-trip suite still
         needs a Docker broker (no in-process / standalone-binary
         alternative for Pulsar's JVM broker), so it stays
         [Trait("Category","Docker")]. NATS no longer uses Testcontainers
         — NatsServerFixture downloads the nats-server release binary and
         runs it as a subprocess, so that suite runs Docker-free on CI. -->
    <PackageReference Include="Testcontainers" />
    <PackageReference Include="Testcontainers.Pulsar" />
    <!-- Testcontainers.Nats — Docker-managed nats:2-alpine for the
         broker-side JetStream / Services round-trip suite added in the
         coverage push. The NatsServerFixture subprocess covers the
         Docker-free CI lane; this Testcontainers fixture covers the
         Docker dev box and lets us exercise the async-iterator state
         machines (NatsJetStreamDiscovery.ListAsync,
         NatsServicesDiscovery.ListAsync, NatsDiscovery.ScanSubjectsAsync,
         StreamJetStreamConsumerAsync) against a real broker. The new
         tests carry [Trait("Category","Docker")] so the default CI
         filter skips them. -->
    <PackageReference Include="Testcontainers.Nats" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\..\src\Kuestenlogik.Bowire\Kuestenlogik.Bowire.csproj" />
    <!-- v2.1 (#325): the interceptor surface (middleware, reverse-proxy
         host, /api/intercepted endpoints, flow / mock stores) moved to
         this dedicated package. The integration suite touches the
         types directly (BowireInterceptorEndpointTests fixtures), so
         pull the package in explicitly. -->
    <ProjectReference Include="..\..\src\Kuestenlogik.Bowire.Interceptor\Kuestenlogik.Bowire.Interceptor.csproj" />
    <!-- Reference the MapLibre extension so the asset-endpoint tests
         (BowireSemanticsEndpointsTests, SemanticsEndpointIntegrationTests)
         find the embedded bundle + vendor assets via the registry's
         assembly-scan sweep. Without this reference the assembly is
         absent from the test AppDomain and `Discover()` returns an
         empty UI-extension list. -->
    <ProjectReference Include="..\..\src\Kuestenlogik.Bowire.Map\Kuestenlogik.Bowire.Map.csproj" />
    <ProjectReference Include="..\..\src\Kuestenlogik.Bowire.Protocol.Grpc\Kuestenlogik.Bowire.Protocol.Grpc.csproj" />
    <ProjectReference Include="..\..\src\Kuestenlogik.Bowire.Protocol.SignalR\Kuestenlogik.Bowire.Protocol.SignalR.csproj" />
    <ProjectReference Include="..\..\src\Kuestenlogik.Bowire.Protocol.GraphQL\Kuestenlogik.Bowire.Protocol.GraphQL.csproj" />
    <ProjectReference Include="..\..\src\Kuestenlogik.Bowire.Protocol.WebSocket\Kuestenlogik.Bowire.Protocol.WebSocket.csproj" />
    <ProjectReference Include="..\..\src\Kuestenlogik.Bowire.Protocol.Mcp\Kuestenlogik.Bowire.Protocol.Mcp.csproj" />
    <!-- Bowire.Mcp brings the workbench-as-MCP-server side + the
         dual-mount registry/dispatcher (#287). The
         DualMcpEndpointCoexistenceTests fixture exercises both
         MapBowireMcp and MapBowireMcpAdapter in the same WebApplication
         to verify they coexist without conflict. -->
    <ProjectReference Include="..\..\src\Kuestenlogik.Bowire.Mcp\Kuestenlogik.Bowire.Mcp.csproj" />
    <ProjectReference Include="..\..\src\Kuestenlogik.Bowire.Protocol.JsonRpc\Kuestenlogik.Bowire.Protocol.JsonRpc.csproj" />
    <ProjectReference Include="..\..\src\Kuestenlogik.Bowire.Protocol.Mqtt\Kuestenlogik.Bowire.Protocol.Mqtt.csproj" />
    <!-- Scanner — the active MQTT retained-poisoning probe (#395) is
         exercised end-to-end against an in-process MQTTnet broker + the
         real BowireMqttProtocol plugin (ActiveMqttProbeIntegrationTests).
         The scanner grants InternalsVisibleTo to this project. -->
    <ProjectReference Include="..\..\src\Kuestenlogik.Bowire.Security.Scanner\Kuestenlogik.Bowire.Security.Scanner.csproj" />
    <ProjectReference Include="..\..\src\Kuestenlogik.Bowire.Protocol.Nats\Kuestenlogik.Bowire.Protocol.Nats.csproj" />
    <ProjectReference Include="..\..\src\Kuestenlogik.Bowire.Protocol.Soap\Kuestenlogik.Bowire.Protocol.Soap.csproj" />
    <ProjectReference Include="..\..\src\Kuestenlogik.Bowire.Protocol.Pulsar\Kuestenlogik.Bowire.Protocol.Pulsar.csproj" />
    <ProjectReference Include="..\..\src\Kuestenlogik.Bowire.Protocol.SocketIo\Kuestenlogik.Bowire.Protocol.SocketIo.csproj" />
    <ProjectReference Include="..\..\src\Kuestenlogik.Bowire.Protocol.OData\Kuestenlogik.Bowire.Protocol.OData.csproj" />
    <ProjectReference Include="..\..\src\Kuestenlogik.Bowire.Protocol.Rest\Kuestenlogik.Bowire.Protocol.Rest.csproj" />
    <!-- OpenApi3 adapter — the REST plugin's OpenAPI seam was extracted
         in 14ac0d1 into per-version adapter packages. The integration
         suite's discover-from-swagger-json tests need an adapter loaded,
         otherwise BowireOpenApiAdapterRegistry.TryGet() returns null and
         discovery quietly produces an empty service list. OpenApi3
         keeps the existing test fixtures (`info.version: 3.0.x`) working
         without forcing them to the 2.x grammar. -->
    <ProjectReference Include="..\..\src\Kuestenlogik.Bowire.Protocol.Rest.OpenApi3\Kuestenlogik.Bowire.Protocol.Rest.OpenApi3.csproj" />
    <!-- Optional Ai package — referenced for the #61 triage endpoint
         in-process tests. The endpoint itself ships in the package;
         the integration suite exercises it via TestServer. -->
    <ProjectReference Include="..\..\src\Kuestenlogik.Bowire.Ai\Kuestenlogik.Bowire.Ai.csproj" />
    <!-- Workspace.Git runtime — referenced for the #196 Phase 2.4
         SSE-endpoint integration suite (FS-watch fanout via
         MapBowireGitWorkspaceEvents) + the embedded-regression test
         that proves the route surfaces 501 when AddBowireGitWorkspace
         was NOT called (no watcher leaks into stock embedded hosts). -->
    <ProjectReference Include="..\..\src\Kuestenlogik.Bowire.Workspace.Git\Kuestenlogik.Bowire.Workspace.Git.csproj" />
  </ItemGroup>
  <ItemGroup>
    <Protobuf Include="Protos/*.proto" GrpcServices="Both" />
  </ItemGroup>
</Project>
