<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <IsPackable>false</IsPackable>
    <IsTestProject>true</IsTestProject>
    <OutputType>Exe</OutputType>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="Microsoft.NET.Test.Sdk" />
    <PackageReference Include="xunit.v3" />
    <PackageReference Include="xunit.runner.visualstudio" />
    <PackageReference Include="coverlet.collector"><PrivateAssets>all</PrivateAssets><IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets></PackageReference>
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\..\src\Kuestenlogik.Bowire\Kuestenlogik.Bowire.csproj" />
    <ProjectReference Include="..\..\src\Kuestenlogik.Bowire.Cli\Kuestenlogik.Bowire.Cli.csproj" />
    <ProjectReference Include="..\..\src\Kuestenlogik.Bowire.Mcp\Kuestenlogik.Bowire.Mcp.csproj" />
    <ProjectReference Include="..\..\src\Kuestenlogik.Bowire.Security.Scanner\Kuestenlogik.Bowire.Security.Scanner.csproj" />
    <!-- Tool brings in BowireConfiguration (bootstrap IConfiguration +
         CLI-flag / legacy-env-var mappings) that the Bowire executable
         uses before WebApplication.CreateBuilder runs. Tested here
         because the alternative — a standalone Kuestenlogik.Bowire.Tool.Tests
         project — is too much ceremony for two units' worth of logic. -->
    <ProjectReference Include="..\..\src\Kuestenlogik.Bowire.Tool\Kuestenlogik.Bowire.Tool.csproj" />
    <!-- Optional Ai package: tests cover the runtime + user-config
         persistence + AddBowireAi overlay precedence. Brought in
         explicitly because the package is opt-in and the rest of the
         test suite shouldn't depend on it being installed. -->
    <ProjectReference Include="..\..\src\Kuestenlogik.Bowire.Ai\Kuestenlogik.Bowire.Ai.csproj" />
    <!-- Optional Help package: tests cover the markdown provider's
         resource scan, front-matter parsing, search ranking, and
         AddBowireHelp registration. Same opt-in shape as the Ai
         package above. -->
    <ProjectReference Include="..\..\src\Kuestenlogik.Bowire.Help\Kuestenlogik.Bowire.Help.csproj" />
    <!-- Optional Telemetry package (#29 v2): AddBowireTelemetry +
         the OpenTelemetry SDK pipeline live here so embedded hosts
         that don't want the OTel transitive weight aren't forced to
         pull it via core. -->
    <ProjectReference Include="..\..\src\Kuestenlogik.Bowire.Extension.Telemetry\Kuestenlogik.Bowire.Extension.Telemetry.csproj" />
    <!-- Tiny fake sidecar executable used by the sidecar plugin
         integration tests. ReferenceOutputAssembly=false because the
         tests only need its built EXE on disk (located via
         AppContext.BaseDirectory navigation), not its types. -->
    <ProjectReference Include="..\Kuestenlogik.Bowire.SidecarFake\Kuestenlogik.Bowire.SidecarFake.csproj">
      <ReferenceOutputAssembly>false</ReferenceOutputAssembly>
      <SkipGetTargetFrameworkProperties>true</SkipGetTargetFrameworkProperties>
      <Private>false</Private>
    </ProjectReference>
  </ItemGroup>
</Project>
