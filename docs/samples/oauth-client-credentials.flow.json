{
  // Sample headless auth flow for `bowire scan --auth-flow` (#190).
  // OAuth 2.0 client-credentials grant: POST client id + secret to the token
  // endpoint, capture the access_token, inject it as `Authorization: Bearer`.
  //
  // The secret is read from the environment ({{env.SCANNER_CLIENT_SECRET}}) so
  // this file is safe to check in — it never contains the credential itself.
  //
  //   SCANNER_CLIENT_SECRET=… bowire scan \
  //     --target https://api.example.com \
  //     --auth-flow docs/samples/oauth-client-credentials.flow.json \
  //     --suite owasp-api
  "grant": "client_credentials",
  "steps": [
    {
      "method": "POST",
      "url": "https://idp.example.com/oauth/token",
      "form": {
        "grant_type": "client_credentials",
        "client_id": "scanner",
        "client_secret": "{{env.SCANNER_CLIENT_SECRET}}",
        "scope": "api.read"
      },
      "capture": [
        { "var": "access_token", "json": "access_token" }
      ]
    }
  ]
}
