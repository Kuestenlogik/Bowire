{
  "metadata": [
    {
      "src": [
        {
          "files": [
            "artifacts/bin/Kuestenlogik.Bowire*/Release/Kuestenlogik.Bowire*.dll"
          ],
          "exclude": [
            "artifacts/bin/Kuestenlogik.Bowire*.Tests*/**",
            "artifacts/bin/Kuestenlogik.Bowire.SidecarFake/**",
            "artifacts/bin/Kuestenlogik.Bowire.IntegrationTests/**",
            "artifacts/bin/Kuestenlogik.Bowire.Testing*/**",
            "artifacts/bin/Kuestenlogik.Bowire.Bundle.*/**",
            "artifacts/bin/Kuestenlogik.Bowire.Tool/**"
          ],
          "src": ".."
        }
      ],
      "dest": "../artifacts/docs/api",
      "includePrivateMembers": false,
      "namespaceLayout": "flattened"
    }
  ],
  "build": {
    "content": [
      {
        "files": ["**.yml"],
        "src": "../artifacts/docs/api",
        "dest": "api"
      },
      {
        "files": [
          "quickstart.md",
          "use-cases.md",
          "features/**.md",
          "features/**/toc.yml",
          "protocols/**.md",
          "protocols/**/toc.yml",
          "samples/**.md",
          "samples/**/toc.yml",
          "ui-guide/**.md",
          "ui-guide/**/toc.yml",
          "architecture/**.md",
          "architecture/**/toc.yml",
          "setup/**.md",
          "setup/**/toc.yml",
          "api/*.md",
          "toc.yml",
          "*.md"
        ]
      }
    ],
    "resource": [
      {
        "files": ["images/**", "favicon.ico"]
      }
    ],
    "dest": "../artifacts/docs",
    "template": ["default", "modern", "templates/bowire"],
    "globalMetadata": {
      "_appTitle": "Bowire Documentation",
      "_appName": "Bowire",
      "_appFaviconPath": "favicon.ico",
      "_enableSearch": false,
      "_enableNewTab": true,
      "_disableContribution": false,
      "_gitContribute": {
        "repo": "https://github.com/Kuestenlogik/Bowire",
        "branch": "main"
      },
      "_gitUrlPattern": "github",
      "_baseUrl": "https://bowire.io/docs/"
    },
    "postProcessors": ["ExtractSearchIndex"]
  }
}
